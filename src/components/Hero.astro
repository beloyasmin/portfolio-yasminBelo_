---
import type { HeroProps } from "@types";
type Props = HeroProps;

const { name, specialty, summary, email } = Astro.props;
---

<section id="hero" class="scroll-mt-24">
  <h1 class="mb-1.5 font-serif text-7xl font-bold text-white">
    {name}
  </h1>

  <p class="mb-9 text-4xl font-bold text-primary">
    {specialty}
  </p>

  <p class="mb-16 text-neutral">
    {summary}
  </p>

  <a
    class="inline-block rounded-full bg-primary px-8 py-5 text-white"
    href={`mailto:${email}`}
  >
    Entrar em contato
  </a>
</section>
