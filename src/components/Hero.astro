---
import type { HeroProps } from "../types";
import { Image } from "astro:assets";

const { name, specialty, summary, email, image } = Astro.props;
---

<section id="hero" class="scroll-mt-24 min-h-screen flex items-center">
  <div class="container mx-auto px-6">
    
    <div class={`grid items-center gap-12 ${image ? "md:grid-cols-2" : "md:grid-cols-1 text-center"}`}>

      <!-- TEXTO -->
      <div>
        <h1 class="mb-4 font-serif text-5xl md:text-7xl font-bold text-white">
          {name}
        </h1>

        <p class="mb-6 text-2xl md:text-4xl font-bold text-primary">
          {specialty}
        </p>

        <p class="mb-10 text-neutral max-w-xl mx-auto md:mx-0">
          {summary}
        </p>

        <a
          class="inline-block rounded-full bg-primary px-8 py-5 text-white shadow-lg hover:shadow-xl transition"
          href={`mailto:${email}`}
        >
          Entrar em contato
        </a>
      </div>

      <!-- FOTO (SÓ SE EXISTIR) -->
      {image && (
        <div class="flex justify-center">
          <div class="relative">

            <!-- Glow -->
            <div class="absolute inset-0 bg-gradient-to-r from-purple-500 to-blue-500 rounded-full blur-2xl opacity-30"></div>

            <!-- Imagem -->
            <Image
              src={image}
              alt={name}
              width={300}
              height={300}
              class="relative w-56 h-56 md:w-72 md:h-72 object-cover rounded-full border-4 border-white shadow-xl"
            />

          </div>
        </div>
      )}

    </div>

  </div>
</section>
