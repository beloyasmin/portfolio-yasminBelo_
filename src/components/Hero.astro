---
import type { HeroProps } from "../types";
import { Image } from "astro:assets";

const { name, specialty, summary, email, image } = Astro.props;
---

<section id="hero" class="relative w-screen left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] bg-[--background-image-hero-gradient] py-24 md:py-32 overflow-hidden scroll-mt-24">
  
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="flex flex-col items-center gap-12 md:flex-row md:items-center md:gap-20">
      
      {image && (
        <div class="flex-shrink-0 relative order-1 md:order-1 anim-entrance" style="animation-delay: 100ms;">
          <div class="w-64 h-64 md:w-80 md:h-80 rounded-full p-1.5 bg-gradient-to-tr from-primary via-slate-700 to-primary shadow-[--shadow-hero-glow] flex items-center justify-center">
            <div class="w-full h-full rounded-full overflow-hidden border-4 border-black">
              <Image
                class="object-cover w-full h-full scale-105"
                src={image}
                width={400}
                height={400}
                alt={`Foto de ${name}`}
                loading="eager"
              />
            </div>
          </div>
        </div>
      )}

      <div class="flex-1 text-center md:text-left order-2 md:order-2">
        <span class="text-white/80 text-lg font-light mb-2 block tracking-tight anim-entrance" style="animation-delay: 300ms;">
          Olá! Meu nome é
        </span>
        
        <h1 class="text-5xl md:text-7xl font-extrabold mb-6 tracking-tight text-primary anim-entrance-slide" style="animation-delay: 500ms;">
          {name}
        </h1>
        
        <p class="text-xl md:text-2xl text-white font-bold mb-4 anim-entrance" style="animation-delay: 700ms;">
          {specialty}
        </p>

        <p class="text-base text-neutral leading-relaxed mb-10 max-w-xl mx-auto md:mx-0 anim-entrance" style="animation-delay: 900ms;">
          {summary}
        </p>

        <div class="flex flex-wrap justify-center md:justify-start gap-4 mb-14 anim-entrance" style="animation-delay: 1100ms;">
          <a href="#about" class="bg-primary hover:brightness-110 text-white px-8 py-3 rounded-xl font-medium transition-all hover:scale-105 shadow-lg shadow-primary/20">
            Sobre Mim →
          </a>
          <a href="#projects" class="bg-white hover:bg-neutral-100 text-black px-8 py-3 rounded-xl font-medium transition-all hover:scale-105">
            Projetos
          </a>
          <a href="#contact" class="bg-transparent border border-white/20 hover:bg-white/10 text-white px-8 py-3 rounded-xl font-medium transition-all">
            Contato
          </a>
        </div>

        <div class="flex flex-wrap justify-center md:justify-start gap-x-8 gap-y-4 text-white text-sm border-t border-white/10 pt-8 anim-entrance" style="animation-delay: 1300ms;">
          <a href="https://wa.me/5521991435429" target="_blank" class="flex items-center gap-2 hover:text-primary transition-colors group">
             <span class="text-[#2fd165] text-lg group-hover:scale-110 transition-transform">📞</span> 
             <span>(21) 99143-5429</span>
          </a>

          <a href="https://www.linkedin.com/in/YasminBelo" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-primary transition-colors group">
            <span class="text-primary font-bold text-lg group-hover:scale-110 transition-transform">in</span> 
            <span class="hover:underline">/YasminBelo</span>
          </a>

          <a href={`mailto:${email}`} class="flex items-center gap-2 hover:text-primary transition-colors group">
             <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-primary group-hover:scale-110 transition-transform">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
             </svg>
             <span>{email}</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Animação de Fade In simples */
  .anim-entrance {
    opacity: 0;
    animation: fadeIn 0.8s ease-out forwards;
  }

  /* Animação de Fade In + Deslizar para o Nome */
  .anim-entrance-slide {
    opacity: 0;
    transform: translateY(20px);
    animation: slideIn 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
