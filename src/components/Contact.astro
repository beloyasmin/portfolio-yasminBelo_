                <p class="text-[#22c55e] text-sm font-medium">(21) 99143-5429</p>
              </div>
            </div>
          </a>

          <a href={`mailto:${email}`} class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-all group">
