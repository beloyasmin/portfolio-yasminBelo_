---
import type { SiteConfig } from "@types";

type Props = Pick<SiteConfig, "author" | "socialLinks">;

const { author, socialLinks } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="w-full bg-[#0b1324] px-5 pt-16 pb-10 text-center text-white">
  <div class="max-w-7xl mx-auto">
    
    <h2 class="text-2xl font-bold mb-3 bg-gradient-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent">
      {author}
    </h2>

    <p class="text-gray-400 text-sm mb-8 tracking-wide">
      Analista de Dados | Business Intelligence | Dashboards
    </p>

    <ul class="flex flex-wrap justify-center gap-x-8 gap-y-4 mb-12">
      {
        socialLinks.map(({ text, href }) => (
          <li>
            <a
              href={href}
              target="_blank"
              class="text-sm text-gray-300 hover:text-purple-400 transition-colors"
            >
              {text}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="w-full border-t border-gray-800/50 mb-8"></div>

    <p class="text-xs text-gray-500 uppercase tracking-widest">
      © {currentYear} {author}. Todos os direitos reservados.
    </p>
  </div>
</footer>
