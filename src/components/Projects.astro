---
import type { ProjectProps } from "@types";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

<section id="projects" class="py-24 bg-[#0f172a] text-white">
  <!-- TÍTULO -->
  <div class="text-center mb-16">
    <h2 class="text-4xl font-bold">Portfólio de Projetos</h2>
    <div class="w-20 h-1 bg-gradient-to-r from-purple-500 to-blue-500 mx-auto mt-4 rounded"></div>
    <p class="text-gray-400 mt-6 max-w-xl mx-auto">
      Conheça alguns dos meus projetos em dados e BI
    </p>
  </div>

  <!-- GRID -->
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 px-6 max-w-7xl mx-auto">
    {
      projects.map((project, index) => (
        <div class="bg-[#1e293b] rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition duration-300 hover:-translate-y-2">
          
          <!-- IMAGEM -->
          <div class="h-52 overflow-hidden">
            <img
              src={project.image}
              alt={project.name}
              class="w-full h-full object-cover hover:scale-105 transition duration-300"
            />
          </div>

          <!-- CONTEÚDO -->
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">{project.name}</h3>
            <p class="text-gray-400 text-sm mb-4">{project.summary}</p>

            <!-- BOTÃO -->
            <button
              onclick={`openModal(${index})`}
              class="w-full bg-gradient-to-r from-purple-600 to-blue-500 py-2 rounded-lg hover:opacity-90 transition"
            >
              Ver detalhes
            </button>
          </div>
        </div>
      ))
    }
  </div>

  <!-- MODAL -->
  <div id="modal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center z-50">
    <div class="bg-[#1e293b] max-w-xl w-full rounded-2xl p-6 relative">

      <!-- FECHAR -->
      <button onclick="closeModal()" class="absolute top-4 right-4 text-gray-400 hover:text-white">
        ✕
      </button>

      <!-- TÍTULO -->
      <h3 id="modalTitle" class="text-2xl font-bold mb-4"></h3>

      <!-- IMAGEM -->
      <img id="modalImage" class="w-full rounded-lg mb-4" />

      <!-- DESCRIÇÃO -->
      <p id="modalDesc" class="text-gray-300 mb-6"></p>

      <!-- BOTÃO -->
      <a
        id="modalLink"
        target="_blank"
        class="block text-center bg-gradient-to-r from-purple-600 to-blue-500 py-2 rounded-lg hover:opacity-90 transition"
      >
        Ver Projeto
      </a>
    </div>
  </div>
</section>

<!-- SCRIPT -->
<script is:inline>
  function openModal(index) {
    const data = document.getElementById("projects-data");
    const projects = JSON.parse(data.textContent);
    const project = projects[index];

    const modal = document.getElementById("modal");
    const title = document.getElementById("modalTitle");
    const image = document.getElementById("modalImage");
    const desc = document.getElementById("modalDesc");
    const link = document.getElementById("modalLink");

    if (modal && title && image && desc && link) {
      modal.classList.remove("hidden");
      title.innerText = project.name;
      image.src = project.image;
      desc.innerText = project.summary;
      link.href = project.linkPreview;
    }
  }

  function closeModal() {
    const modal = document.getElementById("modal");
    if (modal) {
      modal.classList.add("hidden");
    }
  }
</script>

<!-- DADOS PARA O SCRIPT -->
<script id="projects-data" type="application/json" is:inline>
  {JSON.stringify(projects)}
</script>
