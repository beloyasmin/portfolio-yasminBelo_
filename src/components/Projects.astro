---
import { Image } from "astro:assets";
import type { ProjectProps } from "@types";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

<section id="projects" class="py-24 bg-[#0f172a] text-white scroll-mt-24">
  <div class="w-full px-6 md:px-12 lg:px-20">

    <!-- TÍTULO -->
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-2">Portfólio de Projetos</h2>
      <div class="w-20 h-1 bg-gradient-to-r from-[#8b31ff] to-[#3b82f6] mx-auto mb-6"></div>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Conheça alguns dos principais projetos desenvolvidos com foco em Business Intelligence e análise de dados
      </p>
    </div>

    <!-- GRID -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

      {projects.map((project, index) => (
        <div class="bg-[#1e293b] rounded-2xl overflow-hidden shadow-lg hover:scale-105 hover:shadow-2xl transition-all duration-300 group">

          {/* IMAGEM */}
          <div class="overflow-hidden">
            <Image
              src={project.image}
              alt={project.name}
              width={500}
              height={300}
              class="w-full h-48 object-cover group-hover:scale-105 transition"
            />
          </div>

          {/* CONTEÚDO */}
          <div class="p-6">
            <span class="text-purple-400 text-xs font-semibold">
              Projeto
            </span>

            <h3 class="text-xl font-bold mt-2 mb-4">
              {project.name}
            </h3>

            <p class="text-gray-400 text-sm mb-6">
              {project.summary}
            </p>

            {/* BOTÕES */}
            <div class="flex gap-3">
              {project.linkPreview && (
                <button
                  onclick={`openModal(${index})`}
                  class="flex-1 py-3 rounded-xl bg-gradient-to-r from-[#8b31ff] to-[#3b82f6] font-semibold hover:opacity-90 transition"
                >
                  Ver detalhes
                </button>
              )}

              {project.linkSource && (
                <a
                  href={project.linkSource}
                  target="_blank"
                  class="flex-1 py-3 rounded-xl border border-gray-600 text-center hover:bg-white/10 transition"
                >
                  Código
                </a>
              )}
            </div>

          </div>
        </div>
      ))}

    </div>
  </div>

  <!-- MODAL -->
  <div id="modal" class="fixed inset-0 bg-black/70 hidden items-center justify-center z-50">
    <div class="bg-[#1e293b] max-w-2xl w-full rounded-2xl p-8 relative">

      <button onclick="closeModal()" class="absolute top-4 right-4 text-gray-400 hover:text-white">
        ✕
      </button>

      <h3 id="modalTitle" class="text-2xl font-bold mb-6"></h3>

      <img id="modalImage" class="rounded-lg mb-6 w-full" />

      <h4 class="font-semibold mb-2">Descrição:</h4>
      <p id="modalDesc" class="text-gray-400 mb-6"></p>

      <a
        id="modalLink"
        target="_blank"
        class="block w-full text-center py-3 bg-gradient-to-r from-[#8b31ff] to-[#3b82f6] rounded-xl font-semibold"
      >
        Ver Projeto
      </a>

    </div>
  </div>

  <!-- SCRIPT -->
  <script>
    const projects = JSON.parse('{JSON.stringify(projects)}');

    function openModal(index) {
      const project = projects[index];

      document.getElementById("modal").classList.remove("hidden");

      document.getElementById("modalTitle").innerText = project.name;
      document.getElementById("modalImage").src = project.image;
      document.getElementById("modalDesc").innerText = project.summary;
      document.getElementById("modalLink").href = project.linkPreview;
    }

    function closeModal() {
      document.getElementById("modal").classList.add("hidden");
    }
  </script>
</section>
