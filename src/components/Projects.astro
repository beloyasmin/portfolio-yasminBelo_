---
interface Project {
  name: string;
  category: string;
  summary: string;
  descriptionModal: string;
  objectives: string[];
  indicators: string[];
  ferramentas: string[]; 
  image: string;
  linkPreview: string;
}

const { projects } = Astro.props;
---

<section id="projects" class="w-full py-16 bg-[#0b1324] bg-gradient-to-b from-[#0b1324] via-[#0d1529] to-[#0b1324] text-white scroll-mt-24 overflow-hidden">
  
  <div class="max-w-7xl mx-auto px-6 md:px-12 relative">
    
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-3 tracking-tight">Portfólio de Projetos</h2>
      <div class="flex justify-center items-center gap-2 mb-4">
        <div class="w-10 h-1 bg-purple-500 rounded-full"></div>
        <div class="w-2 h-2 bg-purple-500 rounded-full"></div>
        <div class="w-10 h-1 bg-purple-500 rounded-full"></div>
      </div>
    </div>

    <div class="relative group">
      
      <button 
        id="prevBtn" 
        class="absolute -left-2 md:-left-12 top-1/2 -translate-y-1/2 z-10 bg-slate-800/80 border border-slate-700 p-2 rounded-full text-white hover:bg-purple-600 transition-all opacity-0 group-hover:opacity-100 hidden md:block"
        aria-label="Projetos anteriores"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>

      <div 
        id="projectScroll" 
        class="flex gap-6 overflow-x-auto snap-x snap-mandatory scrollbar-hide pb-8 scroll-smooth"
      >
        {projects.map((project: Project, index: number) => (
          <div class="min-w-full md:min-w-[calc(50%-12px)] lg:min-w-[calc(33.333%-16px)] snap-start h-full">
            <div class="rounded-xl border text-card-foreground shadow-sm bg-[#1c2333] border-slate-700 hover:border-purple-500 transition-all duration-300 group hover:shadow-2xl hover:shadow-purple-500/20 flex flex-col h-full">
              
              <div class="relative h-40 sm:h-48 bg-gradient-to-br from-purple-600/20 to-blue-600/20 rounded-t-xl overflow-hidden border-b border-slate-700">
                <img 
                  alt={project.name} 
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" 
                  src={project.image}
                />
              </div>

              <div class="p-4 sm:p-5 flex flex-col flex-grow">
                <div class="mb-2">
                  <span class="text-[10px] font-medium text-purple-400 bg-purple-400/10 px-2 py-0.5 rounded-full uppercase tracking-wider">
                    {project.category}
                  </span>
                </div>
                
                <h3 class="text-lg font-bold text-white mb-3 group-hover:text-purple-400 transition-colors leading-tight uppercase">
                  {project.name}
                </h3>

                <div class="mb-4">
                  <h4 class="text-xs font-semibold text-gray-300 mb-2">Objetivos principais:</h4>
                  <ul class="text-xs text-gray-400 space-y-1">
                    {project.objectives && project.objectives.slice(0, 2).map((obj) => (
                      <li class="flex items-start gap-2">
                        <span class="w-1 h-1 bg-purple-400 rounded-full mt-1.5 flex-shrink-0"></span>
                        <span class="leading-relaxed">{obj}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="mb-6">
  <h4 class="text-xs font-semibold text-gray-300 mb-2">Ferramentas utilizadas:</h4>
  <div class="flex flex-wrap gap-1.5">
    {project.ferramentas && project.ferramentas.map((ferramenta: string) => (
      <span class="text-[10px] bg-blue-500/10 text-blue-300 border border-blue-500/20 px-2 py-0.5 rounded">
        {ferramenta}
      </span>
    ))}
  </div>
</div>

                <button 
                  class="open-modal-btn mt-auto inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-all h-10 px-4 w-full bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-700 hover:to-blue-700 text-white text-sm py-2 shadow-lg shadow-purple-900/20"
                  data-index={index}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-eye"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"></path><circle cx="12" cy="12" r="3"></circle></svg>
                  Ver detalhes
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>

      <button 
        id="nextBtn" 
        class="absolute -right-2 md:-right-12 top-1/2 -translate-y-1/2 z-10 bg-slate-800/80 border border-slate-700 p-2 rounded-full text-white hover:bg-purple-600 transition-all opacity-0 group-hover:opacity-100 hidden md:block"
        aria-label="Próximos projetos"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
  </div>

  <div id="projectModal" class="fixed inset-0 bg-black/90 hidden items-center justify-center z-[100] p-4 backdrop-blur-sm">
    <div class="bg-[#1c2333] rounded-2xl w-full max-w-2xl max-h-[90vh] overflow-y-auto relative border border-slate-700">
      <div class="flex items-center justify-between p-5 border-b border-slate-700 sticky top-0 bg-[#1c2333] z-10">
        <h3 id="modalTitle" class="text-lg font-bold text-purple-400"></h3>
        <button id="closeModal" class="text-gray-400 hover:text-white p-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <div class="p-6">
        <img id="modalImage" class="w-full h-auto rounded-lg mb-6 border border-slate-700 shadow-xl"/>
        <h4 class="text-white font-bold mb-2">Objetivos:</h4>
        <ul id="modalObjectives" class="space-y-2 mb-6"></ul>
        <h4 class="text-white font-bold mb-2">Descrição:</h4>
        <p id="modalDesc" class="text-gray-400 text-sm mb-8 leading-relaxed"></p>
        <a id="modalLink" target="_blank" class="block text-center w-full py-3 bg-purple-600 text-white font-bold rounded-lg hover:bg-purple-700 transition-all">Acessar Projeto</a>
      </div>
    </div>
  </div>

  <style>
    /* Esconde a barra de rolagem mas mantém a função de scroll */
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }
    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  <script is:inline define:vars={{ projects }}>
    // Lógica do Modal
    const modal = document.getElementById("projectModal");
    const closeBtn = document.getElementById("closeModal");
    
    function openModal(index) {
      const p = projects[index];
      document.getElementById("modalTitle").textContent = p.name;
      document.getElementById("modalImage").src = p.image;
      document.getElementById("modalDesc").textContent = p.descriptionModal || p.summary;
      document.getElementById("modalLink").href = p.linkPreview;
      
      const list = document.getElementById("modalObjectives");
      list.innerHTML = "";
      p.objectives?.forEach(obj => {
        const li = document.createElement("li");
        li.className = "flex items-start gap-2 text-xs text-gray-300";
        li.innerHTML = `<span class="w-1.5 h-1.5 bg-purple-500 rounded-full mt-1"></span>${obj}`;
        list.appendChild(li);
      });

      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.style.overflow = "hidden";
    }

    document.querySelectorAll(".open-modal-btn").forEach(btn => {
      btn.addEventListener("click", () => openModal(btn.dataset.index));
    });

    closeBtn.addEventListener("click", () => {
      modal.classList.add("hidden");
      document.body.style.overflow = "auto";
    });

    // Lógica do Carrossel (Setas)
    const scrollContainer = document.getElementById('projectScroll');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');

    if (scrollContainer && prevBtn && nextBtn) {
      const getScrollAmount = () => {
        // Rola o equivalente a um card
        return scrollContainer.querySelector('div').offsetWidth + 24; 
      };

      nextBtn.addEventListener('click', () => {
        scrollContainer.scrollLeft += getScrollAmount();
      });

      prevBtn.addEventListener('click', () => {
        scrollContainer.scrollLeft -= getScrollAmount();
      });
    }
  </script>
</section>
